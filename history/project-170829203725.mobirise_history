      "settings": {
        "meta_descr": "Web Maker Description",
        "title": "上帝給你的一封信",
        "order": 16
      },
      "components": [
        {
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 15px)",
              "padding-bottom": "(@paddingBottom * 15px)"
            },
            "& when (@bg-type = 'color')": {
